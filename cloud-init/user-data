#cloud-config
# Pocket Dev - reproducible first-boot provisioning for the local-console LazyVim
# setup on a Raspberry Pi 4 / Pi 5 (Raspberry Pi OS Lite 64-bit, Bookworm+).
#
# Datasource: NoCloud. Copy this file (plus meta-data, and optionally
# network-config) to the FAT32 boot partition (labeled "bootfs", mounted at
# /boot/firmware on the Pi). cloud-init applies it on first boot - no control
# machine, no SSH needed. See cloud-init/README.md.
#
# BEFORE FLASHING: replace __LOCALUSER_PASSWORD_HASH__ below (see README for the
# `openssl passwd -6` one-liner). Wi-Fi (for Copilot CLI WAN) is configured
# separately via network-config or Raspberry Pi Imager - never commit creds.

hostname: pocketdev
manage_etc_hosts: true

# Raspberry Pi OS Bookworm soft-blocks (rfkill) the Wi-Fi radio until a Wi-Fi
# regulatory country is set - otherwise wlan0 stays DOWN and first boot has no
# internet, so every download below silently fails. bootcmd runs in the very
# first (init-local) stage, BEFORE NetworkManager brings the network up, which is
# the only hook early enough to unblock Wi-Fi for the first boot itself.
# Order matters: set the regulatory country FIRST (the kernel keeps the radio
# rfkill-blocked until cfg80211 has a regdomain), then unblock rfkill LAST so the
# radio comes up already knowing a valid country.
# Change US to your ISO 3166-1 country code (must match your network-config).
bootcmd:
  - sh -c 'mkdir -p /etc/NetworkManager/conf.d && printf "[device]\nwifi.scan-rand-mac-address=no\n\n[wifi]\nregulatory-domain=US\n" > /etc/NetworkManager/conf.d/10-wifi-regdomain.conf'
  - sh -c 'command -v raspi-config >/dev/null 2>&1 && raspi-config nonint do_wifi_country US || true'
  - sh -c 'command -v iw >/dev/null 2>&1 && iw reg set US || true'
  - rfkill unblock wifi || true

package_update: true
package_upgrade: true

# Non-autologin user (login prompt asks for username + password on the console).
users:
  - name: localuser
    groups: [adm, sudo, users, video, render, input, netdev, gpio, i2c, spi, audio, plugdev]
    shell: /bin/bash
    lock_passwd: false
    # Generate with: openssl passwd -6  (see cloud-init/README.md)
    passwd: "__LOCALUSER_PASSWORD_HASH__"
    sudo: ALL=(ALL) ALL

ssh_pwauth: true

packages:
  # Core dev toolchain (apt-provided; Neovim/lazygit/Node come from upstream below)
  - git
  - curl
  - unzip
  - build-essential
  - pkg-config
  - python3-venv
  - python3-pip
  - pipx
  - git-delta
  - ripgrep
  - fd-find
  - fzf
  # No-DE local console: cage (single-app Wayland kiosk) + foot (truecolor terminal)
  - cage
  - foot
  # fontconfig provides fc-cache/fc-list (absent on Lite) and lets foot resolve
  # fonts by name; noto-color-emoji renders :checkhealth's OK/ERROR/WARN emoji markers.
  - fontconfig
  - fonts-noto-color-emoji
  # mDNS so `ssh localuser@pocketdev.local` resolves (co-equal SSH front door, ADR-0001)
  - avahi-daemon
  # Encrypted token storage for the Copilot CLI (keytar -> libsecret -> Secret Service):
  #  - gnome-keyring  : headless Secret Service provider (org.freedesktop.secrets)
  #  - libpam-gnome-keyring : the pam_gnome_keyring.so PAM module (SEPARATE package!
  #                   gnome-keyring ships only the daemon) - without it the PAM lines
  #                   are silently ignored and the login keyring is never unlocked
  #  - libsecret-1-0  : runtime lib the CLI's bundled keytar.node dlopens
  #  - dbus-user-session : socket-activated per-user D-Bus bus at $XDG_RUNTIME_DIR/bus,
  #                        which keytar auto-discovers (no DBUS_SESSION_BUS_ADDRESS needed)
  #  - libsecret-tools : `secret-tool` for verifying the vault (debug aid)
  # The login keyring is unlocked with the console password via PAM (pam_gnome_keyring,
  # see runcmd), and the tty1 launcher starts the 'secrets' component on the user bus.
  # Without all of this the CLI warns "system vault not available" -> plaintext fallback.
  - gnome-keyring
  - libpam-gnome-keyring
  - libsecret-1-0
  - libsecret-tools
  - dbus-user-session

write_files:
  # US keyboard layout for the text console (Raspberry Pi OS defaults to GB, which
  # misplaces @ " # \ | etc.). Applied to the live console by `setupcon` in runcmd.
  - path: /etc/default/keyboard
    permissions: '0644'
    content: |
      XKBMODEL="pc105"
      XKBLAYOUT="us"
      XKBVARIANT=""
      XKBOPTIONS=""
      BACKSPACE="guess"

  # foot config (Tokyo Night palette) is written per-user in runcmd, NOT here:
  # write_files runs before the user exists, so an `owner: localuser` chown fails
  # and the file is unreliable. See the runcmd "foot.ini" step below.

  # On tty1 login (after username + password), launch the fullscreen console.
  # Boots into a SHELL inside foot (not nvim directly) so quitting nvim returns to
  # a prompt instead of a dead end. Only tty1; SSH and other VTs are unaffected.
  - path: /etc/profile.d/10-pocketdev-console.sh
    permissions: '0644'
    content: |
      # Pocket Dev local console: fullscreen cage+foot on the physical console only.
      # Force the US keyboard layout for the Wayland (cage/foot) session too.
      if [ "$(tty)" = "/dev/tty1" ] && [ -z "$WAYLAND_DISPLAY" ]; then
        export XKB_DEFAULT_LAYOUT=us
        # Bring up the Secret Service so the Copilot CLI stores its token encrypted
        # (keytar -> libsecret -> org.freedesktop.secrets) instead of plaintext.
        # PAM (pam_gnome_keyring) already unlocked the login keyring with the login
        # password; here we just ensure a user D-Bus bus exists and that the running
        # keyring daemon exposes the 'secrets' component (PAM auto_start only brings up
        # pkcs11/ssh, and with no desktop nothing else D-Bus-activates secrets).
        export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
        if command -v gnome-keyring-daemon >/dev/null 2>&1; then
          eval "$(gnome-keyring-daemon --start --components=secrets,pkcs11,ssh 2>/dev/null)"
          export SSH_AUTH_SOCK
        fi
        exec cage -s -- foot
      fi

  # USB gadget (CDC-ECM Ethernet over the Pi 4 USB-C port) bring-up script.
  # libcomposite gives a CDC-ECM function (macOS/Linux native; RNDIS is Windows-y).
  # Stable, locally-administered MACs so the host keeps the SAME interface across
  # reboots. Safe to run when dwc2 peripheral mode isn't active yet (no UDC) - it
  # just no-ops, so it can't break a boot that hasn't had the config.txt reboot yet.
  - path: /usr/local/sbin/pocketdev-usb-gadget
    permissions: '0755'
    content: |
      #!/bin/bash
      # Pocket Dev: CDC-ECM USB Ethernet gadget via libcomposite (Pi 4 USB-C OTG).
      set -e
      G=/sys/kernel/config/usb_gadget/pocketdev

      modprobe libcomposite 2>/dev/null || true
      if ! mountpoint -q /sys/kernel/config 2>/dev/null; then
        mount -t configfs none /sys/kernel/config 2>/dev/null || true
      fi

      # Already configured and bound to a UDC? Nothing to do (idempotent).
      if [ -d "$G" ] && [ -s "$G/UDC" ]; then
        exit 0
      fi

      # No UDC means dwc2 peripheral mode isn't active yet (needs the config.txt
      # dtoverlay + a reboot). No-op gracefully so first boot never fails here.
      UDC="$(ls /sys/class/udc 2>/dev/null | head -n1 || true)"
      if [ -z "$UDC" ]; then
        echo "pocketdev-usb-gadget: no UDC (dwc2 peripheral not active yet); skipping" >&2
        exit 0
      fi

      mkdir -p "$G"
      cd "$G"
      echo 0x1d6b > idVendor          # Linux Foundation
      echo 0x0104 > idProduct         # Multifunction Composite Gadget
      echo 0x0100 > bcdDevice
      echo 0x0200 > bcdUSB
      mkdir -p strings/0x409
      echo "pocketdev0001"            > strings/0x409/serialnumber
      echo "Pocket Dev"               > strings/0x409/manufacturer
      echo "Pocket Dev USB Ethernet"  > strings/0x409/product
      mkdir -p configs/c.1/strings/0x409
      echo "CDC ECM"                  > configs/c.1/strings/0x409/configuration
      echo 250                        > configs/c.1/MaxPower
      mkdir -p functions/ecm.usb0
      echo "02:1a:11:00:00:01"        > functions/ecm.usb0/dev_addr   # Pi side
      echo "02:1a:11:00:00:02"        > functions/ecm.usb0/host_addr  # host side
      ln -sf functions/ecm.usb0 configs/c.1/
      ls /sys/class/udc > UDC

  # systemd unit that brings the gadget up on every boot. ConditionPathExists guards
  # so it cleanly skips when dwc2 peripheral mode isn't active (pre-reboot first boot).
  - path: /etc/systemd/system/pocketdev-usb-gadget.service
    permissions: '0644'
    content: |
      [Unit]
      Description=Pocket Dev USB CDC-ECM Ethernet gadget
      After=sys-kernel-config.mount
      Wants=sys-kernel-config.mount
      ConditionPathExists=/sys/class/udc

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      ExecStart=/usr/local/sbin/pocketdev-usb-gadget
      ExecStop=/bin/sh -c 'echo "" > /sys/kernel/config/usb_gadget/pocketdev/UDC 2>/dev/null || true'

      [Install]
      WantedBy=multi-user.target

  # NetworkManager connection for usb0. The Pi is a DHCP CLIENT on the cable: when the
  # Mac runs Internet Sharing it hands the Pi an address + default route + DNS (WAN per
  # plan 3c P1). When the Mac is NOT sharing, IPv4 DHCP simply fails (may-fail) and the
  # link stays up on IPv6 link-local, so avahi still resolves `pocketdev.local` and SSH
  # over the cable works. A higher route metric keeps Wi-Fi (fallback WAN) preferred only
  # when usb0 has no default route. NM keyfiles must be 0600/root.
  - path: /etc/NetworkManager/system-connections/usb0.nmconnection
    permissions: '0600'
    content: |
      [connection]
      id=usb0
      type=ethernet
      interface-name=usb0
      autoconnect=true
      autoconnect-priority=50

      [ipv4]
      method=auto
      may-fail=true
      route-metric=200

      [ipv6]
      method=link-local
      may-fail=true

runcmd:
  # Apply the US keyboard layout written above to the live text console.
  - setupcon --force --save 2>/dev/null || true

  # Auto-unlock the gnome-keyring login keyring with the console login password so
  # the Copilot CLI can store its token encrypted (Secret Service) instead of
  # plaintext. Idempotent: only append if not already present. Covers tty1 login
  # and SSH logins.
  - bash -c 'grep -q pam_gnome_keyring /etc/pam.d/login || printf "\nauth     optional  pam_gnome_keyring.so\nsession  optional  pam_gnome_keyring.so auto_start\n" >> /etc/pam.d/login'
  - bash -c 'grep -q pam_gnome_keyring /etc/pam.d/sshd || printf "\nauth     optional  pam_gnome_keyring.so\nsession  optional  pam_gnome_keyring.so auto_start\n" >> /etc/pam.d/sshd'

  # USB gadget mode (CDC-ECM Ethernet over the Pi 4 USB-C port). The firmware reads
  # config.txt/cmdline.txt only at boot, so these edits take effect on the NEXT boot -
  # gadget mode comes up after the first reboot (which the normal first-boot workflow
  # already involves). Idempotent. BOOT is /boot/firmware on Bookworm, /boot on older.
  - |
    bash -c 'set -e
      BOOT=/boot/firmware; [ -d "$BOOT" ] || BOOT=/boot
      CFG="$BOOT/config.txt"; CMD="$BOOT/cmdline.txt"
      # 1) Put the dwc2 controller in peripheral (gadget) mode.
      if [ -f "$CFG" ] && ! grep -q "^dtoverlay=dwc2,dr_mode=peripheral" "$CFG"; then
        printf "\n# Pocket Dev: USB-C as a USB gadget (CDC-ECM Ethernet)\ndtoverlay=dwc2,dr_mode=peripheral\n" >> "$CFG"
      fi
      # 2) Load dwc2 early. Merge into an existing modules-load= token if present,
      #    else append one. cmdline.txt MUST stay a single line.
      if [ -f "$CMD" ] && ! grep -q "modules-load=.*dwc2" "$CMD"; then
        if grep -q "modules-load=" "$CMD"; then
          sed -i "s/\(modules-load=[^ ]*\)/\1,dwc2/" "$CMD"
        else
          sed -i "s/$/ modules-load=dwc2/" "$CMD"
        fi
      fi'
  # Enable (not start) the gadget service: no UDC exists until the dwc2 reboot, so it
  # would no-op now anyway; it brings usb0 up on every subsequent boot.
  - systemctl enable pocketdev-usb-gadget.service 2>/dev/null || true

  # Telescope/LazyVim expect `fd`; Debian ships the binary as `fdfind`.
  - ln -sf "$(command -v fdfind)" /usr/local/bin/fd 2>/dev/null || true

  # GitHub CLI (gh) from GitHub's official APT repo (arm64).
  - install -d -m 0755 /etc/apt/keyrings
  - 'curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg'
  - chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
  - 'echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list'
  - apt-get -o DPkg::Lock::Timeout=600 update
  - DEBIAN_FRONTEND=noninteractive apt-get -o DPkg::Lock::Timeout=600 install -y gh

  # Latest stable Neovim (apt's is too old for LazyVim), arm64 tarball, system-wide.
  # Guarded so a download hiccup never aborts first boot.
  - |
    bash -c 'set -e; cd /tmp; curl -fsSL -o nvim.tgz https://github.com/neovim/neovim/releases/latest/download/nvim-linux-arm64.tar.gz; rm -rf /opt/nvim-linux-arm64; tar -C /opt -xzf nvim.tgz; d=$(tar -tzf nvim.tgz | head -1 | cut -d/ -f1); ln -sf "/opt/$d/bin/nvim" /usr/local/bin/nvim; rm -f nvim.tgz' || true

  # lazygit (not in Debian repos), arm64. Resolve the version via the release
  # redirect (NOT the rate-limited api.github.com) and use the lowercase `linux`
  # asset name - both were real bugs found on hardware.
  - |
    bash -c 'set -e; cd /tmp; LG=$(curl -fsSLI -o /dev/null -w "%{url_effective}" https://github.com/jesseduffield/lazygit/releases/latest | grep -oP "tag/v\K[^/]+"); curl -fsSL -o lazygit.tgz "https://github.com/jesseduffield/lazygit/releases/download/v${LG}/lazygit_${LG}_linux_arm64.tar.gz"; tar -xzf lazygit.tgz lazygit; install -m 0755 lazygit /usr/local/bin/lazygit; rm -f lazygit lazygit.tgz' || true

  # Ensure localuser owns its home before the per-user installs below (cloud-init wrote
  # some files as root). Also make sure ~/.bashrc exists so nvm's profile setup works.
  - mkdir -p /home/localuser/.config
  - chown -R localuser:localuser /home/localuser
  - runuser -l localuser -c '[ -f ~/.bashrc ] || cp /etc/skel/.bashrc ~/.bashrc'

  # foot.ini (Tokyo Night palette + Nerd Font), written as localuser so it lands in
  # the real home with correct ownership (write_files runs before the user exists).
  - |
    runuser -l localuser -c 'mkdir -p ~/.config/foot && cat > ~/.config/foot/foot.ini <<"INI"
    font=JetBrainsMono Nerd Font:size=12

    [colors]
    alpha=1.0
    background=1a1b26
    foreground=c0caf5
    regular0=15161e
    regular1=f7768e
    regular2=9ece6a
    regular3=e0af68
    regular4=7aa2f7
    regular5=bb9af7
    regular6=7dcfff
    regular7=a9b1d6
    bright0=414868
    bright1=f7768e
    bright2=9ece6a
    bright3=e0af68
    bright4=7aa2f7
    bright5=bb9af7
    bright6=7dcfff
    bright7=c0caf5
    INI' || true

  # Node via nvm (Copilot CLI needs Node >=22), installed for the localuser user (not root).
  - runuser -l localuser -c 'curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.5/install.sh | bash'
  - runuser -l localuser -c 'export NVM_DIR="$HOME/.nvm"; . "$NVM_DIR/nvm.sh"; nvm install 22; nvm alias default 22; npm install -g @github/copilot' || true

  # JetBrainsMono Nerd Font for the localuser user (glyphs live Pi-side in console mode).
  - runuser -l localuser -c 'mkdir -p ~/.local/share/fonts && curl -fsSL -o /tmp/jbmono.zip https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip && unzip -o -q /tmp/jbmono.zip -d ~/.local/share/fonts/JetBrainsMonoNerd && fc-cache -f && rm -f /tmp/jbmono.zip' || true

  # LazyVim: clone the starter, drop its git history (becomes the user's own config).
  # MUST run after the home chown and after nvim is on PATH. Idempotent + re-run-safe:
  # keyed on LazyVim's init.lua marker (NOT mere directory existence), and it clears
  # any stray/partial ~/.config/nvim left by an earlier failed (e.g. offline) boot -
  # otherwise the later snacks step's mkdir would create the dir and block re-cloning.
  - runuser -l localuser -c 'test -f ~/.config/nvim/init.lua || { rm -rf ~/.config/nvim; git clone --depth 1 https://github.com/LazyVim/starter ~/.config/nvim && rm -rf ~/.config/nvim/.git; }' || true

  # Enlarge LazyVim's <C-/> terminal (snacks.nvim) to a large centered float so the
  # Copilot CLI run inside :terminal has room. Only written once LazyVim is actually
  # present (init.lua), so a failed clone never leaves a half-config behind.
  - |
    runuser -l localuser -c 'test -f ~/.config/nvim/init.lua && mkdir -p ~/.config/nvim/lua/plugins && cat > ~/.config/nvim/lua/plugins/snacks.lua <<"LUA"
    -- Make the snacks.nvim terminal (the LazyVim <C-/> toggle) a large centered float
    -- instead of the default ~40% bottom split, so the Copilot CLI has more room.
    return {
      "folke/snacks.nvim",
      opts = {
        styles = {
          terminal = {
            position = "float",
            width = 0.9,
            height = 0.9,
            border = "rounded",
          },
        },
      },
    }
    LUA' || true

  # Pre-install LazyVim plugins headlessly so first launch is fast (only if LazyVim cloned).
  - runuser -l localuser -c 'test -f ~/.config/nvim/init.lua && nvim --headless "+Lazy! sync" +qa 2>/dev/null' || true

  # Final ownership sweep (per-user installs above wrote to ~ as localuser already, but be safe).
  - chown -R localuser:localuser /home/localuser

final_message: |
  Pocket Dev first-boot provisioning complete after $UPTIME seconds.
  Log in on the monitor as 'localuser' to drop into the fullscreen cage+foot console,
  then run `nvim` for LazyVim. One manual step remains: run `copilot` once and
  complete the device-code login in a browser to authenticate the Copilot CLI.
