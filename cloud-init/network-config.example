# cloud-init network-config (NoCloud) — EXAMPLE / TEMPLATE
#
# Wi-Fi gives the Pi the WAN access the Copilot CLI needs. This file holds your
# PSK in plaintext, so it is git-ignored: copy it to `network-config` (no
# extension) on the boot partition and fill in your details. NEVER commit the
# filled copy.
#
#   cp network-config.example network-config   # then edit network-config
#
# Alternatively, skip this file entirely and set Wi-Fi in Raspberry Pi Imager's
# advanced options when flashing, or use Ethernet (no config needed).

version: 2
wifis:
  wlan0:
    dhcp4: true
    optional: true
    access-points:
      "__WIFI_SSID__":
        password: "__WIFI_PSK__"
